# Database Connection - Use your PostgreSQL connection string
# For Vercel/Render, get this from your database provider
DATABASE_URL=postgresql://user:password@localhost:5432/doorsteprepair

# Session Secret - Generate a secure random string for production
# Example: openssl rand -hex 32
SESSION_SECRET=your-secure-random-session-secret-here

# Port - Server port (Vercel/Render will set this automatically)
PORT=5004

# Environment - Set to 'production' when deploying
NODE_ENV=development

# Cron Job Configuration
# URL for internal health checks and scheduled jobs
# For local development: http://localhost:5000/api/health
# For production on Render: https://your-app.onrender.com/api/health
# For production on Vercel: https://your-app.vercel.app/api/health
CRON_JOB_URL=http://localhost:5000/api/health
